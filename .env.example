# การตั้งค่าการเชื่อมต่อ (ให้ตรงกับที่คุณตั้งในหน้าจอ Webhook Settings)
SST_WEBHOOK_SECRET=your_webhook_secret_here
SST_API_URL=http://localhost:3000

# ข้อมูลสำหรับยืนยันตัวตนดึงไฟล์ (External API Key)
SST_CUSTOMER_ID=your_customer_id_here
SST_SECRET_KEY=your_secret_key_here

# พอร์ตที่ Simulator จะรัน (Default: 4000)
PORT=4000
